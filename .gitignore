# ============================================================
# track-mcp .gitignore
# ============================================================

# ------------------------------------------------------------
# Secrets — NEVER commit these
# ------------------------------------------------------------
.secrets/
.env
*.pem
*.key
*.p12
*.pfx

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.whl
MANIFEST
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/
.env.local
.env.*.local

# pytest
.pytest_cache/
.cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# ruff / black
.ruff_cache/

# ------------------------------------------------------------
# Alembic
# ------------------------------------------------------------
# Keep versions/ tracked, but not local state files
*.pyc

# ------------------------------------------------------------
# Docker
# ------------------------------------------------------------
# Local override files (use docker-compose.override.yml for local tweaks)
docker-compose.override.yml

# ------------------------------------------------------------
# OS / Editor
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# JetBrains
.idea/
*.iml
*.ipr
*.iws

# VSCode
.vscode/
*.code-workspace

# Vim
*.swp
*.swo
*~

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Node (for any future front-end)
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# Telemetry data files
# ------------------------------------------------------------
*.csv
*.vbo

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
*.bak
*.tmp
*.orig
.hypothesis/
