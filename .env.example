# ============================================================
# track-mcp environment variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# PostgreSQL / TimescaleDB
# ----------------------------------------------------------
# Host-exposed port for direct DB access (e.g. from local tools)
POSTGRES_PORT=5432

# ----------------------------------------------------------
# MinIO object storage
# ----------------------------------------------------------
# Root (admin) username for the MinIO server
MINIO_ROOT_USER=trackminio

# Host-exposed ports for MinIO API and console
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
# One of: development | staging | production
ENVIRONMENT=development

# Python log level: debug | info | warning | error
LOG_LEVEL=info

# CORS allowed origins (comma-separated)
# Dev:  CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# Prod: CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ----------------------------------------------------------
# Celery
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ----------------------------------------------------------
# Secrets (file paths — referenced by Docker secrets)
# These files must exist before `docker compose up`.
# See README for how to generate them.
# ----------------------------------------------------------
# .secrets/db_password        — PostgreSQL password for the `track` user
# .secrets/minio_root_password — MinIO root password
# .secrets/jwt_secret         — HS256 JWT signing secret (min 32 chars)

# ----------------------------------------------------------
# Cloudflare Tunnel (production only)
# ----------------------------------------------------------
# Token from Zero Trust → Networks → Tunnels → your tunnel → Configure
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ----------------------------------------------------------
# Anthropic (for AI coaching insights)
# ----------------------------------------------------------
ANTHROPIC_API_KEY=your_key_here

# ----------------------------------------------------------
# Feature flags
# ----------------------------------------------------------
# ENABLE_AI_COACHING=true
# ENABLE_SECTOR_ANALYSIS=true
